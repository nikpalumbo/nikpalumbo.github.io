# MIME Type Configuration for SVG files
<IfModule mod_mime.c>
    AddType image/svg+xml .svg .svgz
</IfModule>

# Force SVG MIME type
<FilesMatch "\.svg$">
    Header set Content-Type "image/svg+xml"
</FilesMatch>

# Prevent MIME type sniffing
<IfModule mod_headers.c>
    Header set X-Content-Type-Options nosniff
</IfModule>

# Redirect old work URLs to new case-studies URLs
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^work/?$ /case-studies/ [R=301,L]
    RewriteRule ^work/(.*)$ /case-studies/$1 [R=301,L]
    
    # Block old blog and tag URLs
    RewriteRule ^blog/ /404.html [R=404,L]
    RewriteRule ^tags/ /404.html [R=404,L]
    RewriteRule ^2022- /404.html [R=404,L]
</IfModule>
